# Framework created by Deepak Patil <deepakpatil.slk@gmail.com>\n# ============================================================================
# PLAYWRIGHT FRAMEWORK CONFIGURATION
# ============================================================================

# ============================================================================
# UI & API ENDPOINTS
# ============================================================================

# Base URL for UI tests
# Example: https://playwright.dev/ or https://example.com/
UI_BASE_URL=https://playwright.dev/

# Base URL for API tests
# Example: https://api.example.com/v1 or https://automationexercise.com/api/
API_BASE_URL=https://automationexercise.com/api/productsList

# ============================================================================
# SCREENSHOT CONFIGURATION
# ============================================================================

# Screenshot capture mode during test execution
# Accepted values:
#   - "on"                  : Capture screenshots for every action
#   - "off"                 : No screenshots captured automatically
#   - "only-on-failure"     : Capture screenshots only when tests fail (default)
SCREENSHOT_MODE=on

# Enable step-by-step screenshot capture at each test step
# Accepted values:
#   - "true"                : Capture screenshot after each ScreenshotUtil.capture() call
#   - "false"               : Skip step screenshots, only use SCREENSHOT_MODE (default)
# Note: Step screenshots are saved in /screenshots/ folder with descriptive names
ENABLE_STEP_SCREENSHOTS=true

# ============================================================================
# VIDEO CONFIGURATION
# ============================================================================

# Video recording mode during test execution
# Accepted values:
#   - "on"                  : Record video for all tests
#   - "off"                 : No video recording
#   - "retain-on-failure"   : Only save video recordings when tests fail (default)
# Note: Videos are saved in the configured VIDEO_FOLDER path
VIDEO_MODE=on

# Enable step-by-step video recording at specific test steps
# Accepted values:
#   - "true"                : Record short video clips at each VideoUtil.startStepRecording() call
#   - "false"               : Skip step videos, only use VIDEO_MODE (default)
# Note: Step videos are named with step identifier (e.g., step_navigation_12345.webm)
ENABLE_STEP_VIDEOS=true

# ============================================================================
# TRACE CONFIGURATION
# ============================================================================

# Trace recording mode during test execution
# Accepted values:
#   - "on"                  : Record trace for all tests (large file size)
#   - "off"                 : No trace recording
#   - "on-first-retry"      : Record traces only on first retry (default)
#   - "retain-on-failure"   : Only save traces when tests fail
# Note: Traces are stored in test-results/test_XXXX/artifacts/
# Traces can be opened with: npx playwright show-trace <trace-file>
TRACE_MODE=on

# Enable trace attachments to HTML test report
# Accepted values:
#   - "true"                : Attach trace files to HTML report for easy access
#   - "false"               : Store traces in artifacts folder only (default)
# Note: Trace attachments appear in the HTML report as downloadable files
ENABLE_TRACE_ATTACHMENTS=true

# ============================================================================
# PROJECT & OUTPUT CONFIGURATION
# ============================================================================

# Project name (used in test run folder naming and logs)
# Default: "amazon_UI_API_project"
# PROJECT_NAME=amazon_UI_API_project

# Output folder for test results (logs, screenshots, reports)
# Default: "test-results"
# Each test run creates a subfolder: test-results/test_YYYY-MM-DDTHH-mm-ss-sssZ_PROJECT_NAME/
# OUTPUT_FOLDER=test-results

# Execution log file name
# Default: "execution.log"
# LOG_FILE_NAME=execution.log

# Video storage folder (for both regular and step videos)
# Default: "./videos" (relative to project root)
# VIDEO_FOLDER=videos

# ============================================================================
# PROXY CONFIGURATION (in config/proxy-config.json)
# ============================================================================
# HTTP_PROXY=http://proxy-host:port
# HTTPS_PROXY=http://proxy-host:port
# PROXY_USERNAME=username
# PROXY_PASSWORD=password

